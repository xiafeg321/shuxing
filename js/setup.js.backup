};

// 用户选择的数据
let userSelections = {
    zodiac: null,
    mbti: null,
    chatHistory: ''
};

// 当前步骤
let currentStep = 1;
const totalSteps = 4;

document.addEventListener('DOMContentLoaded', function() {
    // 初始化页面
    initSetupPage();
    
    // 绑定事件
    bindSetupEvents();
    
    // 加载保存的数据
    loadSavedSelections();
});

// 初始化设置页面
function initSetupPage() {
    // 生成星座选项
    generateZodiacOptions();
    
    // 生成MBTI选项
    generateMbtiOptions();
    
    // 初始化字符计数
    updateCharCount();
    
    // 更新进度指示
    updateProgress();
}

// 生成星座选项
function generateZodiacOptions() {
    const zodiacGrid = document.getElementById('zodiac-grid');
    if (!zodiacGrid) return;
    
    zodiacGrid.innerHTML = '';
    
    Object.entries(personalityData.zodiac).forEach(([key, data]) => {
        const zodiacItem = document.createElement('div');
        zodiacItem.className = 'zodiac-item';
        zodiacItem.dataset.zodiac = key;
        
        zodiacItem.innerHTML = `
            <div class="zodiac-symbol">${data.symbol}</div>
            <div class="zodiac-name">${data.name}</div>
            <div class="zodiac-element">${data.element}象星座</div>
        `;
        
        zodiacGrid.appendChild(zodiacItem);
    });
}

// 生成MBTI选项
function generateMbtiOptions() {
    const mbtiGrid = document.getElementById('mbti-grid');
    if (!mbtiGrid) return;
    
    mbtiGrid.innerHTML = '';
    
    Object.entries(personalityData.mbti).forEach(([key, data]) => {
        const mbtiItem = document.createElement('div');
        mbtiItem.className = 'mbti-item';
        mbtiItem.dataset.mbti = key;
        
        mbtiItem.innerHTML = `
            <div class="mbti-type">${data.name}</div>
            <div class="mbti-category">${data.category}</div>
        `;
        
        mbtiGrid.appendChild(mbtiItem);
    });
}

// 绑定事件
function bindSetupEvents() {
    // 星座选择
    document.querySelectorAll('.zodiac-item').forEach(item => {
        item.addEventListener('click', function() {
            selectZodiac(this.dataset.zodiac);
        });
    });
    
    // MBTI选择
    document.querySelectorAll('.mbti-item').forEach(item => {
        item.addEventListener('click', function() {
            selectMbti(this.dataset.mbti);
        });
    });
    
    // 聊天记录输入
    const chatInput = document.getElementById('chat-history');
    if (chatInput) {
        chatInput.addEventListener('input', function() {
            updateCharCount();
            userSelections.chatHistory = this.value;
            saveSelections();
        });
    }
    
    // 清空聊天记录
    const clearChatBtn = document.getElementById('clear-chat');
    if (clearChatBtn) {
        clearChatBtn.addEventListener('click', function() {
            if (confirm('确定要清空聊天记录吗？')) {
                document.getElementById('chat-history').value = '';
                updateCharCount();
                userSelections.chatHistory = '';
                saveSelections();
            }
        });
    }
    
    // 示例聊天记录
    const sampleChatBtn = document.getElementById('sample-chat');
    if (sampleChatBtn) {
        sampleChatBtn.addEventListener('click', function() {
            const sampleChat = `你：今天工作累吗？
TA：还好啦～就是会议有点多 😅
你：晚上想吃什么？
TA：想吃火锅！天气冷最适合了 ❤️
你：那我订位置？
TA：好呀好呀，你最懂我了 😊

你：周末有什么计划？
TA：还没想好呢，你想做什么？
你：看电影怎么样？
TA：可以呀，最近有部爱情片好像不错 💕`;
            
            document.getElementById('chat-history').value = sampleChat;
            updateCharCount();
            userSelections.chatHistory = sampleChat;
            saveSelections();
        });
    }
    
    // 导航按钮
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    
    if (prevBtn) {
        prevBtn.addEventListener('click', goToPrevStep);
    }
    
    if (nextBtn) {
        nextBtn.addEventListener('click', goToNextStep);
    }
    
    // 编辑模型按钮
    const editModelBtn = document.getElementById('edit-model');
    if (editModelBtn) {
        editModelBtn.addEventListener('click', function() {
            currentStep = 1;
            updateProgress();
            showStep(currentStep);
        });
    }
    
    // 开始对话按钮
    const startChatBtn = document.getElementById('start-chat');
    if (startChatBtn) {
        startChatBtn.addEventListener('click', function() {
            // 保存完整模型
            savePersonalityModel();
            
            // 跳转到对话页面（待创建）
            alert('人格模型已保存！对话页面正在开发中...');
            // window.location.href = 'chat.html';
        });
    }
}

// 选择星座
function selectZodiac(zodiacKey) {
    const zodiacData = personalityData.zodiac[zodiacKey];
    if (!zodiacData) return;
    
    // 更新选择状态
    document.querySelectorAll('.zodiac-item').forEach(item => {
        item.classList.remove('selected');
    });
    
    const selectedItem = document.querySelector(`.zodiac-item[data-zodiac="${zodiacKey}"]`);
    if (selectedItem) {
        selectedItem.classList.add('selected');
    }
    
    // 更新预览
    userSelections.zodiac = zodiacKey;
    updateZodiacPreview(zodiacKey, zodiacData);
    
    // 保存选择
    saveSelections();
    
    // 检查是否可以进入下一步
    checkNextStepAvailability();
}

// 更新星座预览
function updateZodiacPreview(zodiacKey, zodiacData) {
    const preview = document.getElementById('zodiac-preview');
    const zodiacName = document.getElementById('selected-zodiac');
    const zodiacDesc = document.getElementById('zodiac-description');
    
    if (preview && zodiacName && zodiacDesc) {
        preview.style.display = 'block';
        zodiacName.textContent = `${zodiacData.name} ${zodiacData.symbol}`;
        zodiacDesc.textContent = zodiacData.trait;
    }
}

// 选择MBTI
function selectMbti(mbtiKey) {
    const mbtiData = personalityData.mbti[mbtiKey];
    if (!mbtiData) return;
    
    // 更新选择状态
    document.querySelectorAll('.mbti-item').forEach(item => {
        item.classList.remove('selected');
    });
    
    const selectedItem = document.querySelector(`.mbti-item[data-mbti="${mbtiKey}"]`);
    if (selectedItem) {
        selectedItem.classList.add('selected');
    }
    
    // 更新预览
    userSelections.mbti = mbtiKey;
    updateMbtiPreview(mbtiKey, mbtiData);
    
    // 保存选择
    saveSelections();
    
    // 检查是否可以进入下一步
    checkNextStepAvailability();
}

// 更新MBTI预览
function updateMbtiPreview(mbtiKey, mbtiData) {
    const preview = document.getElementById('mbti-preview');
    const mbtiName = document.getElementById('selected-mbti');
    const mbtiDesc = document.getElementById('mbti-description');
    
    if (preview && mbtiName && mbtiDesc) {
        preview.style.display = 'block';
        mbtiName.textContent = `${mbtiData.name} (${mbtiData.category})`;
        mbtiDesc.textContent = mbtiData.trait;
    }
}

// 更新字符计数
function updateCharCount() {
    const chatInput = document.getElementById('chat-history');
    const charCount = document.getElementById('char-count');
    
    if (chatInput && charCount) {
        const count = chatInput.value.length;
        charCount.textContent = count;
        
        // 根据字符数改变颜色
        if (count > 1000) {
            charCount.style.color = '#ff6b6b';
        } else if (count > 500) {
            charCount.style.color = '#ffa726';
        } else {
            charCount.style.color = '#4a4a6a';
        }
    }
}

// 检查下一步是否可用
function checkNextStepAvailability() {
    const nextBtn = document.getElementById('next-btn');
    if (!nextBtn) return;
    
    let canProceed = false;
    
    switch (currentStep) {
        case 1: // 星座选择
            canProceed = userSelections.zodiac !== null;
            break;
        case 2: // MBTI选择
            canProceed = userSelections.mbti !== null;
            break;
        case 3: // 聊天记录
            canProceed = userSelections.chatHistory.trim().length > 0;
            break;
        case 4: // 完成
            canProceed = true;
            break;
    }
    
    if (canProceed) {
        nextBtn.disabled = false;
        nextBtn.classList.remove('btn-disabled');
    } else {
        nextBtn.disabled = true;
        nextBtn.classList.add('btn-disabled');
    }
}

// 转到下一步
function goToNextStep() {
    if (currentStep < totalSteps) {
        currentStep++;
        updateProgress();
        showStep(currentStep);
        checkNextStepAvailability();
    }
}

// 转到上一步
function goToPrevStep() {
    if (currentStep > 1) {
        currentStep--;
        updateProgress();
        showStep(currentStep);
        checkNextStepAvailability();
    }
}

// 更新进度指示
function updateProgress() {
    const progressSteps = document.querySelectorAll('.progress-step');
    
    progressSteps.forEach((step, index) => {
        const stepNumber = index + 1;
        
        if (stepNumber < currentStep) {
            step.classList.add('completed');
            step.classList.remove('active');
        } else if (stepNumber === currentStep) {
            step.classList.add('active');
            step.classList.remove('completed');
        } else {
            step.classList.remove('active', 'completed');
        }
    });
    
    // 更新导航按钮
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    
    if (prevBtn) {
        prevBtn.style.display = currentStep > 1 ? 'flex' : 'none';
    }
    
    if (nextBtn) {
        if (currentStep === totalSteps) {
            nextBtn.innerHTML = '完成';
            nextBtn.id = 'complete-btn';
        } else {
            nextBtn.innerHTML = '下一步 <i class="fas fa-arrow-right"></i>';
            nextBtn.id = 'next-btn';
        }
    }
}

// 显示指定步骤
function showStep(stepNumber) {
    // 隐藏所有步骤
    document.querySelectorAll('.setup-section').forEach(section => {
        section.style.display = 'none';
        section.classList.remove('active');
    });
    
    // 显示当前步骤
    const currentSection = document.getElementById(getSectionId(stepNumber));
    if (currentSection) {
        currentSection.style.display = 'block';
        currentSection.classList.add('active');
        
        // 如果是完成步骤，更新摘要
        if (stepNumber === 4) {
            updateSummary();
        }
    }
}

// 获取步骤对应的section id
function getSectionId(stepNumber) {
    switch (stepNumber) {
        case 1: return 'zodiac-section';
        case 2: return 'mbti-section';
        case 3: return 'chat-section';
        case 4: return 'complete-section';
        default: return 'zodiac-section';
    }
}

// 更新完成页面的摘要
function updateSummary() {
    // 更新星座
    const zodiacData = personalityData.zodiac[userSelections.zodiac];
    if (zodiacData) {
        document.getElementById('summary-zodiac').textContent = 
            `${zodiacData.name} ${zodiacData.symbol} - ${zodiacData.trait}`;
    }
    
    // 更新MBTI
    const mbtiData = personalityData.mbti[userSelections.mbti];
    if (mbtiData) {
        document.getElementById('summary-mbti').textContent = 
            `${mbtiData.name} (${mbtiData.category}) - ${mbtiData.trait}`;
    }
    
    // 分析语言风格
    const styleAnalysis = analyzeChatStyle(userSelections.chatHistory);
    document.getElementById('summary-style').textContent = styleAnalysis;
    
    // 生成人格洞察
    const insight = generatePersonalityInsight();
    document.getElementById('personality-insight-text').textContent = insight;
}

// 分析聊天风格
function analyzeChatStyle(chatText) {
    if (!chatText || chatText.trim().length === 0) {
        return '未提供聊天记录，将使用默认风格';
    }
    
    const analysis = [];
    
    // 检查语气词
    const toneWords = ['呀', '啦', '呢', '嘛', '喔', '诶'];
    const hasToneWords = toneWords.some(word => chatText.includes(word));
    if (hasToneWords) analysis.push('喜欢使用语气词');
    
    // 检查表情符号
    const emojiRegex = /[\u{1F600}-\u{1F64F}]|[\u{1F300}-\u{1F5FF}]|[\u{1F680}-\u{1F6FF}]/gu;
    const hasEmoji = emojiRegex.test(chatText);
    if (hasEmoji) analysis.push('喜欢使用表情符号');
    
    // 检查标点习惯
    const hasEllipsis = chatText.includes('...') || chatText.includes('……');
    if (hasEllipsis) analysis.push('习惯使用省略号');
    
    const hasExclamation = (chatText.match(/!/g) || []).length > 3;
    if (hasExclamation) analysis.push('喜欢使用感叹号');
    
    const hasQuestion = (chatText.match(/\?/g) || []).length > 3;
    if (hasQuestion) analysis.push('喜欢提问');
    
    // 返回分析结果
    if (analysis.length === 0) {
        return '聊天风格较为中性直接';
    }
    
    return analysis.join('，');
}

// 分析聊天风格
function analyzeChatStyle(chatText) {
    if (!chatText || chatText.trim().length === 0) {
        return '未提供聊天记录，将使用默认风格';
    }
    
    const analysis = [];
    
    // 检查语气词
    const toneWords = ['呀', '啦', '呢', '嘛', '喔', '诶', '哇', '噢'];
    const hasToneWords = toneWords.some(word => chatText.includes(word));
    if (hasToneWords) analysis.push('喜欢使用语气词');
    
    // 检查表情符号和颜文字
    const emojiCount = (chatText.match(/[\u{1F600}-\u{1F64F}]/gu) || []).length;
    const kaomojiCount = (chatText.match(/[\(\)\[\]\{\}][^\w\s]|[^\w\s][\(\)\[\]\{\}]/g) || []).length;
    
    if (emojiCount > 0 || kaomojiCount > 0) {
        analysis.push('经常使用表情符号');
    }
    
    // 检查句子长度
    const sentences = chatText.split(/[。！？.!?]/).filter(s => s.trim().length > 0);
    const avgSentenceLength = sentences.reduce((sum, s) => sum + s.length, 0) / (sentences.length || 1);
    
    if (avgSentenceLength < 10) {
        analysis.push('说话简洁直接');
    } else if (avgSentenceLength > 20) {
        analysis.push('表达较为详细');
    }
    
    // 检查特定词汇
    const affectionateWords = ['宝贝', '亲爱的', '乖乖', '傻瓜', '笨蛋'];
    const hasAffectionate = affectionateWords.some(word => chatText.includes(word));
    if (hasAffectionate) analysis.push('会用亲昵称呼');
    
    // 返回分析结果
    if (analysis.length === 0) {
        return '语言风格较为中性';
    }
    
    return analysis.join('，');
}

// 生成人格洞察
function generatePersonalityInsight() {
    const zodiacData = personalityData.zodiac[userSelections.zodiac];
    const mbtiData = personalityData.mbti[userSelections.mbti];
    
    if (!zodiacData || !mbtiData) {
        return '请先完成星座和MBTI选择';
    }
    
    const insights = [];
    
    // 星座洞察
    const zodiacInsights = {
        '白羊': '行动力强，喜欢直接表达',
        '金牛': '注重实际，需要安全感',
        '双子': '思维活跃，善于沟通',
        '巨蟹': '情感细腻，重视家庭',
        '狮子': '自信大方，需要被关注',
        '处女': '注重细节，追求完美',
        '天秤': '追求平衡，善于交际',
        '天蝎': '情感深沉，直觉敏锐',
        '射手': '热爱自由，乐观开朗',
        '摩羯': '务实稳重，目标明确',
        '水瓶': '独立思考，创新思维',
        '双鱼': '浪漫感性，富有同情'
    };
    
    if (zodiacInsights[userSelections.zodiac]) {
        insights.push(zodiacInsights[userSelections.zodiac]);
    }
    
    // MBTI洞察
    const mbtiInsights = {
        'INTJ': '喜欢独立思考，注重效率',
        'INTP': '逻辑性强，好奇心重',
        'ENTJ': '领导型人格，目标导向',
        'ENTP': '创新思维，喜欢辩论',
        'INFJ': '富有同情，追求意义',
        'INFP': '理想主义，忠于信念',
        'ENFJ': '善于激励，关心他人',
        'ENFP': '热情创意，乐观积极',
        'ISTJ': '责任感强，遵守规则',
        'ISFJ': '支持型人格，细致负责',
        'ESTJ': '组织能力强，务实',
        'ESFJ': '社交型人格，注重和谐',
        'ISTP': '动手能力强，冷静分析',
        'ISFP': '审美敏锐，享受当下',
        'ESTP': '行动派，适应力强',
        'ESFP': '活力四射，热爱社交'
    };
    
    if (mbtiInsights[userSelections.mbti]) {
        insights.push(mbtiInsights[userSelections.mbti]);
    }
    
    // 组合洞察
    if (insights.length === 0) {
        return '这是一个独特的人格组合，需要更多了解';
    }
    
    return `TA可能${insights.join('，同时')}。在对话中，TA可能会表现出这些特点。`;
}

// 保存选择到本地存储
function saveSelections() {
    try {
        // 保存到两个键名，确保兼容性
        localStorage.setItem('数星_用户选择', JSON.stringify(userSelections));
        localStorage.setItem('shuxing_user_settings', JSON.stringify(userSelections));
        console.log('选择已保存');
    } catch (error) {
        console.error('保存选择失败:', error);
    }
}

// 从本地存储加载选择
function loadSavedSelections() {
    try {
        // 优先使用新的键名，如果不存在则使用旧的
        let saved = localStorage.getItem('shuxing_user_settings');
        if (!saved) {
            saved = localStorage.getItem('数星_用户选择');
        }
        
        if (saved) {
            const parsed = JSON.parse(saved);
            userSelections = { ...userSelections, ...parsed };
            
            // 恢复UI状态
            restoreSelections();
            
            console.log('选择已加载');
        }
    } catch (error) {
        console.error('加载选择失败:', error);
    }
}

// 恢复选择到UI
function restoreSelections() {
    // 恢复星座选择
    if (userSelections.zodiac) {
        const zodiacItem = document.querySelector(`.zodiac-item[data-zodiac="${userSelections.zodiac}"]`);
        if (zodiacItem) {
            zodiacItem.click();
        }
    }
    
    // 恢复MBTI选择
    if (userSelections.mbti) {
        const mbtiItem = document.querySelector(`.mbti-item[data-mbti="${userSelections.mbti}"]`);
        if (mbtiItem) {
            mbtiItem.click();
        }
    }
    
    // 恢复聊天记录
    if (userSelections.chatHistory) {
        const chatInput = document.getElementById('chat-history');
        if (chatInput) {
            chatInput.value = userSelections.chatHistory;
            updateCharCount();
        }
    }
}

// 保存完整人格模型
function savePersonalityModel() {
    const model = {
        ...userSelections,
        createdAt: new Date().toISOString(),
        modelId: 'model_' + Date.now(),
        zodiacData: personalityData.zodiac[userSelections.zodiac],
        mbtiData: personalityData.mbti[userSelections.mbti],
        styleAnalysis: analyzeChatStyle(userSelections.chatHistory),
        insight: generatePersonalityInsight()
    };
    
    try {
        // 保存当前模型
        localStorage.setItem('数星_当前模型', JSON.stringify(model));
        
        // 保存到历史记录
        let history = JSON.parse(localStorage.getItem('数星_模型历史') || '[]');
        history.unshift(model);
        if (history.length > 10) history = history.slice(0, 10); // 只保留最近10个
        localStorage.setItem('数星_模型历史', JSON.stringify(history));
        
        console.log('人格模型已保存:', model);
        return model;
    } catch (error) {
        console.error('保存模型失败:', error);
        return null;
    }
}

// 工具函数：获取元素样式
function getElementStyle(element, styleProperty) {
    return window.getComputedStyle(element).getPropertyValue(styleProperty);
}

// 工具函数：添加加载动画
function showLoading(element) {
    if (!element) return;
    
    const originalHTML = element.innerHTML;
    element.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 处理中...';
    element.disabled = true;
    
    return function() {
        element.innerHTML = originalHTML;
        element.disabled = false;
    };
}

// 工具函数：显示提示消息
function showToast(message, type = 'info') {
    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    toast.textContent = message;
    
    document.body.appendChild(toast);
    
    // 显示动画
    setTimeout(() => {
        toast.classList.add('show');
    }, 10);
    
    // 自动消失
    setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => {
            if (toast.parentNode) {
                toast.parentNode.removeChild(toast);
            }
        }, 300);
    }, 3000);
}

