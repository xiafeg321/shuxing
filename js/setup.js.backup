        'ENFJ': { name: 'ENFJ', trait: '激励引导，善于交际，关心他人', category: '外交家' },
        'ENFP': { name: 'ENFP', trait: '热情创意，充满灵感，乐观积极', category: '外交家' },
        'ISTJ': { name: 'ISTJ', trait: '责任传统，务实可靠，注重细节', category: '守护者' },
        'ISFJ': { name: 'ISFJ', trait: '支持关怀，细致负责，保护他人', category: '守护者' },
