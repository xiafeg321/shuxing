        'ISFP': { name: 'ISFP', trait: '审美体验，温和敏感，享受当下', category: '探险家' },
        'ESTP': { name: 'ESTP', trait: '行动适应，精力充沛，现实导向', category: '探险家' },
        'ESFP': { name: 'ESFP', trait: '活力社交，热情开朗，享受生活', category: '探险家' }
